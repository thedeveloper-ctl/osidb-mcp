# osidb-mcp environment variables
# Copy this file to .env and fill in the values.
# Variables set in the shell environment take precedence over .env values.
# Requires: pip install osidb-mcp[dotenv]

# ── OSIDB connection (required) ──────────────────────────────────────
OSIDB_BASE_URL=https://osidb.example.com
OSIDB_AUTH=kerberos
# OSIDB_USERNAME=           # required when OSIDB_AUTH=basic
# OSIDB_PASSWORD=           # required when OSIDB_AUTH=basic
# OSIDB_VERIFY_SSL=true
# OSIDB_USER_AGENT=

# ── Server mode ──────────────────────────────────────────────────────
# OSIDB_MCP_ACCESS_MODE=readonly   # readonly (default) | readwrite

# ── Jira (required for internal comments) ────────────────────────────
# JIRA_URL=https://your-jira-instance.atlassian.net
# JIRA_ACCESS_TOKEN=
# JIRA_API_EMAIL=

# ── AEGIS (optional, AI-assisted CVE analysis) ───────────────────────
# AEGIS_URL=https://aegis.example.com
